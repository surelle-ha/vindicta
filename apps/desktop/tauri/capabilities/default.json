{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default Vindicta capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "claude-version-check", "cmd": "claude", "args": ["--version"], "sidecar": false },
        { "name": "claude-cmd-version", "cmd": "claude.cmd", "args": ["--version"], "sidecar": false },
        { "name": "codex-version", "cmd": "codex", "args": ["--version"], "sidecar": false },
        { "name": "codex-cmd-version", "cmd": "codex.cmd", "args": ["--version"], "sidecar": false },
        { "name": "codex-login-status", "cmd": "codex", "args": ["login", "status"], "sidecar": false },
        { "name": "codex-cmd-login-status", "cmd": "codex.cmd", "args": ["login", "status"], "sidecar": false },
        {
          "name": "codex-exec",
          "cmd": "codex",
          "args": [
            "exec",
            "-c",
            { "validator": "model_reasoning_effort=\"(low|medium|high|xhigh)\"" },
            "-C",
            { "validator": "[^\\u0000-\\u001f\\u007f]+" },
            "--skip-git-repo-check",
            "--sandbox",
            { "validator": "(read-only|workspace-write)" },
            "--color",
            "never",
            "-o",
            { "validator": "[^\\u0000-\\u001f\\u007f]+" },
            { "validator": "(?s).*" }
          ],
          "sidecar": false
        },
        {
          "name": "codex-cmd-exec",
          "cmd": "codex.cmd",
          "args": [
            "exec",
            "-c",
            { "validator": "model_reasoning_effort=\"(low|medium|high|xhigh)\"" },
            "-C",
            { "validator": "[^\\u0000-\\u001f\\u007f]+" },
            "--skip-git-repo-check",
            "--sandbox",
            { "validator": "(read-only|workspace-write)" },
            "--color",
            "never",
            "-o",
            { "validator": "[^\\u0000-\\u001f\\u007f]+" },
            { "validator": "(?s).*" }
          ],
          "sidecar": false
        },
        {
          "name": "node-codex-exec",
          "cmd": "node",
          "args": [
            { "validator": "[^\\u0000-\\u001f\\u007f]+\\\\AppData\\\\Roaming\\\\npm\\\\node_modules\\\\@openai\\\\codex\\\\bin\\\\codex\\.js" },
            "exec",
            "-c",
            { "validator": "model_reasoning_effort=\"(low|medium|high|xhigh)\"" },
            "-C",
            { "validator": "[^\\u0000-\\u001f\\u007f]+" },
            "--skip-git-repo-check",
            "--sandbox",
            { "validator": "(read-only|workspace-write)" },
            "--color",
            "never",
            "-o",
            { "validator": "[^\\u0000-\\u001f\\u007f]+" },
            { "validator": "(?s).*" }
          ],
          "sidecar": false
        },
        { "name": "npm-version", "cmd": "npm", "args": ["--version"], "sidecar": false },
        { "name": "npm-cmd-version", "cmd": "npm.cmd", "args": ["--version"], "sidecar": false },
        { "name": "npm-install-codex", "cmd": "npm", "args": ["install", "-g", "@openai/codex@latest"], "sidecar": false },
        { "name": "npm-cmd-install-codex", "cmd": "npm.cmd", "args": ["install", "-g", "@openai/codex@latest"], "sidecar": false },
        {
          "name": "wsl-exec",
          "cmd": "wsl",
          "args": ["bash", "-c", { "validator": "(?s).*" }],
          "sidecar": false
        },
        { "name": "wsl-version", "cmd": "wsl", "args": ["--version"], "sidecar": false },
        {
          "name": "git-clone",
          "cmd": "git",
          "args": [
            "clone",
            "--",
            { "validator": "((https?|ssh|git)://[^\\s\"'`$;&|<>]+|[A-Za-z0-9._-]+@[A-Za-z0-9.-]+:[A-Za-z0-9._~/-]+(?:\\.git)?)" },
            { "validator": "[^\\u0000-\\u001f\\u007f]+" }
          ],
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "claude-run",
          "cmd": "claude",
          "args": [
            "--output-format",
            "stream-json",
            "--verbose",
            "--print",
            { "validator": "(?s).*" }
          ],
          "sidecar": false
        },
        {
          "name": "node-mcp-server",
          "cmd": "node",
          "args": [
            "-e",
            { "validator": "(?s).*" }
          ],
          "sidecar": false
        }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" },
        { "path": "$HOME/**" },
        { "path": "?:/**" }
      ]
    },
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save",
    "store:allow-load"
  ]
}
